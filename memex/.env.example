# Copy to .env and fill in your values.
# Python backend reads this via python-dotenv at startup.

# ── LLM ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini          # override to gpt-4o for higher quality
LLM_MODEL=gpt-4o-mini             # used by the orchestrator

# ── Debate engine ───────────────────────────────────────────────────────
DEBATE_ROUNDS=2                   # rounds of agent research + synthesis (1=fast, 3=thorough)

# ── News sources ────────────────────────────────────────────────────────
NEWSAPI_KEY=...                   # NewsAPI.org key (also accepted as NEWSAPI_API_KEY)
TWITTER_BEARER_TOKEN=...          # Twitter API v2 bearer token

# ── Social sources ──────────────────────────────────────────────────────
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...

# ── Tavily — web search + full-text extraction (webcrawler source) ──────
# Docs: https://docs.tavily.com/welcome
# Get key: https://app.tavily.com/home  (free tier: 1 000 credits/month)
TAVILY_API_KEY=...

# ── Jina AI ─────────────────────────────────────────────────────────────
JINA_API_KEY=...                  # optional — higher rate limits on r.jina.ai (Reader)

# ── Prediction markets ──────────────────────────────────────────────────
# Metaculus: required — API returns 401 for unauthenticated requests since 2024
# Get token at: https://www.metaculus.com/accounts/settings/account/#api-access
METACULUS_API_TOKEN=your_metaculus_token_here

# ── Database (pgvector) ─────────────────────────────────────────────────
POSTGRES_DSN=postgresql://user:password@localhost:5432/memex

# ── Supabase (alternative to self-hosted Postgres) ──────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_SIGNUPS_TABLE=waitlist_signups
SUPABASE_NEWS_USERS_TABLE=news_users
SUPABASE_NEWS_TOPICS_TABLE=news_user_topics
SUPABASE_NEWS_TOPIC_RUNS_TABLE=news_user_topic_runs
SUPABASE_NEWS_ITEMS_TABLE=news_user_knowledge_items

# ── Email (waitlist confirmations) ──────────────────────────────────────
RESEND_API_KEY=re_...
WAITLIST_FROM_EMAIL=hello@withmemex.com
WAITLIST_CONFIRM_SUBJECT=You're on the Memex waitlist
WAITLIST_SITE_URL=https://withmemex.com
WAITLIST_ADMIN_TOKEN=...          # secret token for GET /api/signup/list

# ── Local embedding model (ingest pipeline relevance scoring) ────────────
NEWS_USE_LOCAL_EMBEDDINGS=true    # set false to use keyword-only fallback
NEWS_LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2
NEWS_SEMANTIC_MIN_SIMILARITY=0.2
NEWS_SEMANTIC_WEIGHT=20
NEWS_KEYWORD_WEIGHT=8
